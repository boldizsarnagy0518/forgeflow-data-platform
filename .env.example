# Synthetic local-only credentials. Change these outside the portfolio demo.
POSTGRES_DB=forgeflow
POSTGRES_USER=forgeflow
POSTGRES_PASSWORD=forgeflow_local_only
FORGEFLOW_DATABASE_URL=postgresql://forgeflow:forgeflow_local_only@127.0.0.1:5432/forgeflow
# API/dashboard containers use the SQL-created local read-only role:
# postgresql://forgeflow_reader:forgeflow_reader_local_only@postgres:5432/forgeflow

MINIO_ROOT_USER=forgeflow
MINIO_ROOT_PASSWORD=forgeflow_local_only
FORGEFLOW_S3_ENDPOINT=http://127.0.0.1:9000
FORGEFLOW_S3_ACCESS_KEY=forgeflow
FORGEFLOW_S3_SECRET_KEY=forgeflow_local_only
FORGEFLOW_S3_BUCKET=forgeflow-raw

FORGEFLOW_DATA_DIR=.forgeflow/data
FORGEFLOW_ARTIFACT_DIR=.forgeflow/artifacts
FORGEFLOW_DBT_PROJECT_DIR=dbt
FORGEFLOW_DBT_PROFILES_DIR=dbt
FORGEFLOW_DBT_TARGET=local
FORGEFLOW_LOG_LEVEL=INFO
FORGEFLOW_MAX_PAGE_SIZE=100
FORGEFLOW_MAX_PAGE_OFFSET=10000
FORGEFLOW_ENABLE_WRITES=false
FORGEFLOW_AI_PROVIDER=deterministic
FORGEFLOW_OPENAI_MODEL=gpt-5.4-mini

# Optional. Never commit a real value.
OPENAI_API_KEY=
